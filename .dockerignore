# --- Files not needed by the Dockerfile ---
# The image only copies: src/, requirements.txt, alembic.ini,
# migrations/, scripts/docker_entrypoint.sh

# Tests
tests/

# Dev / CI tooling
.devcontainer/
.bumpcalver/
bumpcalver-history.json
makefile
pyproject.toml

# Docs & meta
README.md
CONSOLIDATION_SUMMARY.md
LICENSE

# Local database & data directory
data/

# Docker compose configs
docker-compose/

# Environment files (secrets must not enter the image)
.env
.env-sample
.env.local

# Git
.git/
.gitignore
.dockerignore

