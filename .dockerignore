__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage artefacts
.pytest_cache/
.ruff_cache/
htmlcov/
.tox/
.coverage
.coverage.*
coverage.xml
report.xml
*.cover
.hypothesis/

# Editor & OS noise
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
